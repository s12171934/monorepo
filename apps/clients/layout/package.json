{
	"name": "layout",
	"private": true,
	"version": "0.0.0",
	"type": "module",
	"scripts": {
		"dev": "bun run build && (bun run dev:watch --skip-initial & bun run preview)",
		"dev:watch": "bun run ../../../scripts/watch-build.ts .",
		"build": "tsc -b && vite build",
		"preview": "vite preview --host 127.0.0.1 --port 3002 --strictPort"
	},
	"dependencies": {
		"react": "^19.2.4",
		"react-dom": "^19.2.4"
	},
	"devDependencies": {
		"@originjs/vite-plugin-federation": "^1.4.1",
		"@types/node": "^24.12.2",
		"@types/react": "^19.2.14",
		"@types/react-dom": "^19.2.3",
		"@vitejs/plugin-react": "^6.0.1",
		"globals": "^17.4.0",
		"typescript": "~6.0.2",
		"vite": "^8.0.4"
	}
}
